# === Facebook Page Config ===
# REQUIRED
FB_PAGE_ID=your_page_id_here
FB_PAGE_ACCESS_TOKEN=your_page_access_token_here
# REQUIRED for webhook signature verification (security critical)
FB_APP_SECRET=your_app_secret_here
# REQUIRED — pick any random string, set the SAME value in FB webhook setup
FB_VERIFY_TOKEN=pick_a_random_string_here
FB_PAGE_NAME=Karl C

# === Telegram Config ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# === Google Gemini Config ===
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# === Enrollment / Gmail checker (IMAP) ===
# The enrollment checker and Xendit payment lookup read your Gmail via IMAP.
# To enable:
#   1. Turn on 2-Step Verification on your Google account.
#   2. Generate an "App password" at https://myaccount.google.com/apppasswords
#      (16 characters — paste as-is, spaces or no spaces both work).
#   3. Fill in the two values below. Leave both blank to disable Gmail features.
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Your operator email (used to filter system emails out of enrollment scans)
OWNER_EMAIL=
# Systeme.io "From:" address that sends enrollment / verification emails.
# Default is course@karlcomboy.com — only change if Systeme is configured
# to send from a different address.
SYSTEME_SENDER=course@karlcomboy.com

# === Admin / debug ===
# If set, the /messages debug endpoint becomes reachable at
#   /messages?token=<ADMIN_TOKEN>
# Leave empty to disable the endpoint entirely.
ADMIN_TOKEN=

# === Logging ===
LOG_LEVEL=INFO

# === Directories (auto-set in Docker) ===
DATA_DIR=/app/data
REPORT_DIR=/app/data/reports
